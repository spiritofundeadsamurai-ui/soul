# ═══════════════════════════════════════════════════════
# Soul AI — Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ─── LLM Provider (choose one) ───────────────────────
# Local (Ollama) — Free, private, no API key needed
SOUL_PROVIDER=ollama
SOUL_OLLAMA_URL=http://localhost:11434
SOUL_OLLAMA_MODEL=qwen3:14b

# Cloud providers (uncomment one)
# SOUL_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# SOUL_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# SOUL_PROVIDER=gemini
# GEMINI_API_KEY=...
# SOUL_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# SOUL_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
# SOUL_PROVIDER=together
# TOGETHER_API_KEY=...

# ─── Soul Identity ───────────────────────────────────
# Master passphrase (set during soul-setup)
# SOUL_MASTER_PASSPHRASE=your-secret-passphrase

# Soul name (optional, default: "Soul")
# SOUL_NAME=Soul

# ─── Server (HTTP API + Web UI) ─────────────────────
SOUL_PORT=47779
SOUL_HOST=0.0.0.0

# ─── Database ────────────────────────────────────────
# SQLite database path (default: ~/.soul/soul.db)
# SOUL_DB_PATH=~/.soul/soul.db

# ─── Channels (optional) ─────────────────────────────
# Telegram bot
# TELEGRAM_BOT_TOKEN=123456:ABC-...
# Discord bot
# DISCORD_BOT_TOKEN=...

# ─── Web Search (optional) ───────────────────────────
# SERPER_API_KEY=...
# TAVILY_API_KEY=tvly-...

# ─── Security ────────────────────────────────────────
# Rate limit (requests per minute per IP)
# SOUL_RATE_LIMIT=15
# Max message length
# SOUL_MAX_MESSAGE_LENGTH=50000
